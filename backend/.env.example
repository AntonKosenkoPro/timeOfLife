# Postgres connection (used by the server). Tests use SQLite in-memory and ignore this.
DATABASE_URL=postgresql://tol:tol@localhost:5432/tol

# JWT HS256 signing secret. MUST be >= 32 bytes. Generate with:
#   openssl rand -base64 48
JWT_SECRET=please-change-me-to-a-32+-byte-random-secret-value

# Access/refresh token TTLs (seconds).
ACCESS_TOKEN_TTL=900
REFRESH_TOKEN_TTL=2592000

# JWT issuer claim.
JWT_ISSUER=timeoflife

# bcrypt cost. 12 for production, 4 for tests/dev (faster).
BCRYPT_COST=12

# Email backend: "console" (prints link to stdout, dev) or "mailgun" (prod).
EMAIL_BACKEND=console

# Mailgun (required only when EMAIL_BACKEND=mailgun).
MAILGUN_API_KEY=
MAILGUN_DOMAIN=
MAILGUN_FROM=Time of Life <no-reply@your-mailgun-domain>
MAILGUN_API_BASE_URL=https://api.mailgun.net

# Deep-link bases used in email bodies.
RESET_LINK_BASE=timeoflife://reset
VERIFY_LINK_BASE=timeoflife://verify