# ---- Time of Life backend (Go) -------------------------------------------
# Copy to .env and fill in real values. The server fails fast at boot if
# required security values are missing or too short.

# Postgres connection (used by the server in real runs). Tests use SQLite
# in-memory and ignore this.
DATABASE_URL=postgresql://tol:tol@localhost:5432/tol

# JWT HS256 signing secret. MUST be >= 32 bytes. Generate with:
#   openssl rand -base64 48
JWT_SECRET=please-change-me-to-a-32+-byte-random-secret-value

# Token TTLs (Go duration; seconds if a bare integer).
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=720h

# JWT issuer claim.
JWT_ISSUER=timeoflife

# Email backend: "console" (prints code + magic link to stdout, dev) or "mailgun".
EMAIL_BACKEND=console

# OTP settings. OTP_EXPIRY is a Go duration (10m). OTP_ATTEMPTS_MAX caps wrong
# attempts per code before the code is rejected with otp_attempts_exceeded.
OTP_EXPIRY=10m
OTP_ATTEMPTS_MAX=5

# Magic link base emitted in the email. The code is appended as ?code=<code>.
OTP_MAGIC_LINK_BASE=timeoflife://verify

# Optional override of the OTP email body template. Use {{code}} and
# {{magic_link}} placeholders. NOTE: Apple's iOS autofill detection is
# empirical — you may need to tune this template so the 6-digit code stands
# alone on its own line for Mail's .oneTimeCode heuristic to pick it up.
OTP_EMAIL_TEMPLATE=

# Mailgun (required only when EMAIL_BACKEND=mailgun).
MAILGUN_API_KEY=
MAILGUN_DOMAIN=
MAILGUN_FROM=Time of Life <no-reply@your-mailgun-domain>
MAILGUN_API_BASE_URL=https://api.mailgun.net

# Rate limiting (in-memory token bucket, per IP+email).
RATE_REQUEST_PER_WINDOW=5
RATE_VERIFY_PER_WINDOW=10
RATE_WINDOW=1m

# HTTP listen address.
HTTP_ADDR=:8080