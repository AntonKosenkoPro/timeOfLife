DATABASE_URL=postgres://postgres:postgres@localhost:5432/timeoflife?sslmode=disable
JWT_SECRET=change-me-to-a-random-string-at-least-32-bytes-long
EMAIL_BACKEND=console
PORT=8080
OTP_EXPIRY=10m
OTP_MAX_ATTEMPTS=5

# Optional: override the OTP email body templates (Go text/template). The code
# MUST stay on its own line in the text body for iOS .oneTimeCode autofill.
#OTP_EMAIL_TEMPLATE=
#OTP_EMAIL_HTML_TEMPLATE=

# Mailgun (EMAIL_BACKEND=mailgun). Leave commented to keep using console/SES.
#MAILGUN_DOMAIN=
#MAILGUN_API_KEY=
#MAILGUN_FROM=noreply@example.com

# AWS SES (EMAIL_BACKEND=ses) — the real mail sender. All four are required
# when EMAIL_BACKEND=ses. In production, .env is NOT hand-edited on the VM: the
# CI/CD pipeline (`.github/workflows/backend.yml`) regenerates /opt/timeoflife/.env
# from GitHub Actions encrypted secrets on every deploy. This file is only the
# local-dev template. Never commit real credentials.
# Before sending to arbitrary recipients, verify a sending domain/email and
# request SES Production access (the sandbox only delivers to verified addresses).
#AWS_ACCESS_KEY_ID=
#AWS_SECRET_ACCESS_KEY=
#AWS_REGION=eu-west-1
#SES_FROM=noreply@your-verified-domain.com

# Sign in with Apple (F2). Leave APPLE_CLIENT_ID empty to disable the feature
# (the /auth/apple route is not registered and the iOS button is inert).
# When enabled, set it to the app's Bundle ID — Apple puts the Bundle ID in the
# identity token's `aud` claim for a native iOS app.
#APPLE_CLIENT_ID=com.antonkosenko.timeoflife
#APPLE_JWKS_URL=https://appleid.apple.com/auth/keys
# Trusted reverse proxies (FURPS R1/S5). Comma-separated IPs/CIDRs allowed to
# set X-Forwarded-For / X-Real-IP, which are used for per-client rate limiting.
# Empty (default) = trust nobody: forwarded headers are ignored and the direct
# TCP peer is used. Set this to your load balancer/proxy CIDR in production so
# rate limiting sees the real client IP; otherwise clients can spoof the header
# to bypass rate limits.
#TRUSTED_PROXIES=10.0.0.0/8
